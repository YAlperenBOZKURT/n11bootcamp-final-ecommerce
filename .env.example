# ============================================
# .env.example
# ============================================
# Bu dosya GİT'E COMMIT EDİLİR, gerçek değerler YOKTUR.
# Gerçek değerler .env dosyasında tutulur ve .env .gitignore'dadır.
#
# Kullanım:
#   cp .env.example .env
#   # .env dosyasını gerçek değerlerle doldur
# ============================================


# ============================================
# Database (PostgreSQL)
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=n11ecommerce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ============================================
# RabbitMQ
# ============================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=changeme

# ============================================
# Cache (Redis)
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# MinIO (Object Storage)
# ============================================
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_PUBLIC_HOST=localhost
MINIO_PUBLIC_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_BUCKET=products


# ============================================
# JWT
# ============================================
# ÖNEMLİ: Production'da en az 256-bit random bir değer olmalı
# Üretmek için: openssl rand -base64 64
JWT_SECRET=change-this-to-a-very-long-random-string-at-least-256-bits
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000
APP_COOKIES_SECURE=false
APP_COOKIES_SAMESITE=Lax


# ============================================
# Iyzico (Payment Gateway)
# ============================================
# Sandbox credentials: https://sandbox-merchant.iyzipay.com
IYZICO_API_KEY=sandbox-your-api-key
IYZICO_SECRET_KEY=sandbox-your-secret-key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_CALLBACK_URL=http://localhost:8080/api/payments/callback
PAYMENT_PROVIDER=iyzico


# ============================================
# Mail (Notification Service)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password


# ============================================
# Gateway / Application
# ============================================
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
GATEWAY_CORS_ALLOWED_ORIGIN=http://localhost:5173

# ============================================
# Search
# ============================================
SPRING_ELASTICSEARCH_URIS=http://elasticsearch:9200




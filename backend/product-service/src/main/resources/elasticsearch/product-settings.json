{
  "analysis": {
    "analyzer": {
      "turkish_standard": {
        "type": "custom",
        "tokenizer": "standard",
        "filter": ["lowercase", "turkish_stop", "turkish_stemmer", "asciifolding"]
      }
    },
    "filter": {
      "turkish_stop": {
        "type": "stop",
        "stopwords": "_turkish_"
      },
      "turkish_stemmer": {
        "type": "stemmer",
        "language": "turkish"
      }
    }
  }
}
